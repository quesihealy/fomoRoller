# Which TTS backend to use: google | elevenlabs | typecast (default: google)
# TTS_PROVIDER=google

# Key for whichever provider you use
GOOGLE_TTS_API_KEY=your_google_cloud_api_key
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# TYPECAST_API_KEY=your_typecast_api_key

# Optional: pin one voice instead of a random pool voice per MP3
# TTS_VOICE_ID=your_voice_id
# VOICE_POOL_SIZE=20

BURNING_MAN_API_KEY=your_burning_man_api_key
# BURNING_MAN_YEAR=2026
# OUTPUT_DIR=./audio
